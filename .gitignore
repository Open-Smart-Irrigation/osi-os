# Dist
/dist

# Deploy build artifacts
/react_gui.tar.gz

# Local scratch / golden images (large, not committed)
/tmp/

# Hidden files
/.*

# Symlinks
/conf/.config
/conf/files
/conf/patches
/openwrt/patches

# Visual brainstorming companion
.superpowers/

# Track CI workflows / .github content (the /.* rule would otherwise ignore them)
!/.github/

# Track the agent skill library only; keep the rest of .claude/ (settings, local state) ignored
!/.claude/
/.claude/*
!/.claude/skills/
