{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://contracts.opensmartirrigation.org/sync-schema/resources.schema.json",
    "title": "Sync Resource Schema Registry",
    "description": "Canonical resource types and their required fields for sync.",
    "definitions": {
        "Uuid": {
            "type": "string",
            "pattern": "^(?:[0-9A-Fa-f]{32}|[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12})$"
        },
        "NullableUuid": {
            "type": ["string", "null"],
            "pattern": "^(?:[0-9A-Fa-f]{32}|[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12})$"
        },
        "CanonicalUuid": {
            "type": "string",
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "NullableCanonicalUuid": {
            "type": ["string", "null"],
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "CanonicalUtcTimestamp": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$",
            "format": "date-time"
        },
        "NullableCanonicalUtcTimestamp": {
            "type": ["string", "null"],
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$",
            "format": "date-time"
        },
        "Eui64": {
            "type": "string",
            "pattern": "^[0-9A-F]{16}$"
        },
        "NullableEui64": {
            "type": ["string", "null"],
            "pattern": "^[0-9A-F]{16}$"
        },
        "Zone": {
            "type": "object",
            "required": ["zone_id", "name"],
            "properties": {
                "zone_id": {"type": "integer", "minimum": 1},
                "name": {"type": "string", "minLength": 1},
                "area_m2": {"type": ["number", "null"], "minimum": 0},
                "irrigation_efficiency_pct": {"type": ["number", "null"], "minimum": 0, "maximum": 100},
                "crop_type": {"type": ["string", "null"]},
                "soil_type": {"type": ["string", "null"]},
                "irrigation_method": {"type": ["string", "null"]},
                "scheduling_mode": {"type": "string", "enum": ["local", "cloud"]},
                "prediction_card": {"type": "boolean"},
                "deleted_at": {"type": ["string", "null"], "format": "date-time"}
            }
        },
        "ZoneDesiredStateUser": {
            "type": "object",
            "additionalProperties": false,
            "required": ["user_uuid"],
            "properties": {
                "user_uuid": {"$ref": "#/definitions/CanonicalUuid"},
                "username": {"type": ["string", "null"], "maxLength": 64},
                "cloudUserId": {"type": ["integer", "null"], "minimum": 1}
            }
        },
        "ZoneDesiredState": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "contract_version",
                "zone_uuid",
                "name",
                "gateway_device_eui",
                "timezone",
                "latitude",
                "longitude",
                "phenological_stage",
                "calibration_key",
                "crop_type",
                "variety",
                "soil_type",
                "irrigation_method",
                "area_m2",
                "irrigation_efficiency_pct",
                "scheduling_mode",
                "prediction_card_enabled",
                "notes",
                "sync_version",
                "deleted_at",
                "user"
            ],
            "properties": {
                "contract_version": {"type": "integer", "const": 1},
                "zone_uuid": {"$ref": "#/definitions/CanonicalUuid"},
                "name": {"type": "string", "minLength": 1, "maxLength": 128},
                "gateway_device_eui": {"$ref": "#/definitions/Eui64"},
                "timezone": {"type": "string", "minLength": 1, "maxLength": 64},
                "latitude": {"type": ["number", "null"], "minimum": -90, "maximum": 90},
                "longitude": {"type": ["number", "null"], "minimum": -180, "maximum": 180},
                "phenological_stage": {"type": ["string", "null"], "maxLength": 64},
                "calibration_key": {"type": ["string", "null"], "maxLength": 128},
                "crop_type": {"type": ["string", "null"], "maxLength": 128},
                "variety": {"type": ["string", "null"], "maxLength": 128},
                "soil_type": {"type": ["string", "null"], "maxLength": 128},
                "irrigation_method": {"type": ["string", "null"], "maxLength": 128},
                "area_m2": {"type": ["number", "null"], "minimum": 0},
                "irrigation_efficiency_pct": {"type": ["number", "null"], "minimum": 0, "maximum": 100},
                "scheduling_mode": {"type": "string", "enum": ["local", "server_preferred"]},
                "prediction_card_enabled": {"type": "integer", "enum": [0, 1]},
                "notes": {"type": ["string", "null"], "maxLength": 4096},
                "sync_version": {"type": "integer", "minimum": 1},
                "deleted_at": {"type": "null"},
                "user": {"$ref": "#/definitions/ZoneDesiredStateUser"}
            }
        },
        "ZoneDeleteState": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "contract_version",
                "zone_uuid",
                "gateway_device_eui",
                "sync_version",
                "deleted_at"
            ],
            "properties": {
                "contract_version": {"type": "integer", "const": 1},
                "zone_uuid": {"$ref": "#/definitions/CanonicalUuid"},
                "gateway_device_eui": {"$ref": "#/definitions/Eui64"},
                "sync_version": {"type": "integer", "minimum": 1},
                "deleted_at": {"$ref": "#/definitions/CanonicalUtcTimestamp"}
            }
        },
        "Device": {
            "type": "object",
            "required": ["deveui", "type_id"],
            "properties": {
                "deveui": {"$ref": "#/definitions/Eui64"},
                "type_id": {
                    "type": "string",
                    "enum": [
                        "STREGA_VALVE",
                        "DRAGINO_LSN50",
                        "KIWI_SENSOR",
                        "TEKTELIC_CLOVER",
                        "SENSECAP_S2120",
                        "AQUASCOPE_LORAIN",
                        "MILESIGHT_UC512"
                    ]
                },
                "name": {"type": ["string", "null"]},
                "zone_id": {"type": ["integer", "null"]},
                "chameleon_enabled": {"type": ["integer", "null"], "enum": [0, 1, null]},
                "chameleon_swt1_depth_cm": {"type": ["number", "null"]},
                "chameleon_swt2_depth_cm": {"type": ["number", "null"]},
                "chameleon_swt3_depth_cm": {"type": ["number", "null"]},
                "deleted_at": {"type": ["string", "null"], "format": "date-time"}
            }
        },
        "Schedule": {
            "type": "object",
            "required": ["zone_id", "trigger_metric"],
            "properties": {
                "zone_id": {"type": "integer", "minimum": 1},
                "trigger_metric": {"type": "string", "enum": ["SWT_WM1", "SWT_WM2", "SWT_AVG", "SWT_1", "SWT_2", "SWT_3", "DENDRO"]},
                "threshold_kpa": {"type": "number"},
                "irrigation_duration_min": {"type": "integer", "minimum": 1},
                "enabled": {"type": "boolean"},
                "deleted_at": {"type": ["string", "null"], "format": "date-time"}
            }
        },
        "IrrigationScheduleDesiredState": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "contract_version", "zone_uuid", "gateway_device_eui",
                "trigger_metric", "threshold_kpa", "enabled",
                "duration_minutes", "response_mode", "sync_version",
                "deleted_at", "last_applied_at"
            ],
            "properties": {
                "contract_version": {"type": "integer", "const": 1},
                "zone_uuid": {"$ref": "#/definitions/CanonicalUuid"},
                "gateway_device_eui": {"$ref": "#/definitions/Eui64"},
                "trigger_metric": {"type": "string", "enum": ["SWT_WM1", "SWT_WM2", "SWT_AVG", "SWT_1", "SWT_2", "SWT_3", "DENDRO"]},
                "threshold_kpa": {"type": "number"},
                "enabled": {"type": "integer", "enum": [0, 1]},
                "duration_minutes": {"type": "integer", "minimum": 1, "maximum": 240},
                "response_mode": {"type": "string", "enum": ["proportional", "fixed", "aggressive"]},
                "sync_version": {"type": "integer", "minimum": 1},
                "deleted_at": {"$ref": "#/definitions/NullableCanonicalUtcTimestamp"},
                "last_applied_at": {"$ref": "#/definitions/NullableCanonicalUtcTimestamp"}
            }
        },
        "IrrigationCalibrationDesiredState": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "contract_version", "zone_uuid", "gateway_device_eui",
                "measured_flow_rate_lpm", "measurement_method", "measured_at",
                "sync_version", "deleted_at", "last_applied_at"
            ],
            "properties": {
                "contract_version": {"type": "integer", "const": 1},
                "zone_uuid": {"$ref": "#/definitions/CanonicalUuid"},
                "gateway_device_eui": {"$ref": "#/definitions/Eui64"},
                "measured_flow_rate_lpm": {"type": "number", "minimum": 0, "not": {"const": 0}},
                "measurement_method": {"type": "string", "minLength": 1, "maxLength": 200},
                "measured_at": {"$ref": "#/definitions/CanonicalUtcTimestamp"},
                "sync_version": {"type": "integer", "minimum": 1},
                "deleted_at": {"$ref": "#/definitions/NullableCanonicalUtcTimestamp"},
                "last_applied_at": {"$ref": "#/definitions/NullableCanonicalUtcTimestamp"}
            }
        },
        "ScopedUser": {
            "type": "object",
            "required": ["user_uuid", "username", "role", "disabled_at", "sync_version", "gateway_device_eui"],
            "properties": {
                "user_uuid": {"$ref": "#/definitions/Uuid"},
                "username": {"type": "string", "minLength": 1, "maxLength": 64},
                "role": {"type": "string", "enum": ["admin", "researcher", "viewer"]},
                "disabled_at": {"$ref": "#/definitions/NullableCanonicalUtcTimestamp"},
                "sync_version": {"type": "integer", "minimum": 1},
                "gateway_device_eui": {"$ref": "#/definitions/Eui64"},
                "occurred_at": {"$ref": "#/definitions/CanonicalUtcTimestamp"}
            }
        },
        "ScopedUserCommand": {
            "allOf": [
                {"$ref": "#/definitions/ScopedUser"},
                {
                    "required": ["base_sync_version"],
                    "propertyNames": {
                        "enum": ["user_uuid", "username", "role", "disabled_at", "sync_version", "gateway_device_eui", "occurred_at", "base_sync_version", "password_hash"]
                    },
                    "properties": {
                        "base_sync_version": {"type": "integer", "minimum": 0},
                        "password_hash": {"type": "string", "pattern": "^\\$2[aby]\\$[0-9]{2}\\$.{53}$"}
                    }
                }
            ]
        },
        "UserZoneAssignment": {
            "type": "object",
            "required": ["assignment_uuid", "user_uuid", "zone_uuid", "assigned_by_user_uuid", "sync_version", "deleted_at", "gateway_device_eui"],
            "properties": {
                "assignment_uuid": {"$ref": "#/definitions/Uuid"},
                "user_uuid": {"$ref": "#/definitions/Uuid"},
                "zone_uuid": {"$ref": "#/definitions/Uuid"},
                "assigned_by_user_uuid": {"$ref": "#/definitions/NullableUuid"},
                "sync_version": {"type": "integer", "minimum": 1},
                "deleted_at": {"$ref": "#/definitions/NullableCanonicalUtcTimestamp"},
                "gateway_device_eui": {"$ref": "#/definitions/Eui64"},
                "occurred_at": {"$ref": "#/definitions/CanonicalUtcTimestamp"}
            }
        },
        "UserZoneAssignmentCommand": {
            "allOf": [
                {"$ref": "#/definitions/UserZoneAssignment"},
                {
                    "required": ["base_sync_version"],
                    "propertyNames": {
                        "enum": ["assignment_uuid", "user_uuid", "zone_uuid", "assigned_by_user_uuid", "sync_version", "deleted_at", "gateway_device_eui", "occurred_at", "base_sync_version"]
                    },
                    "properties": {
                        "base_sync_version": {"type": "integer", "minimum": 0}
                    }
                }
            ]
        },
        "UserPlotAssignment": {
            "type": "object",
            "required": ["assignment_uuid", "user_uuid", "plot_uuid", "assigned_by_user_uuid", "sync_version", "deleted_at", "gateway_device_eui"],
            "properties": {
                "assignment_uuid": {"$ref": "#/definitions/Uuid"},
                "user_uuid": {"$ref": "#/definitions/Uuid"},
                "plot_uuid": {"$ref": "#/definitions/Uuid"},
                "assigned_by_user_uuid": {"$ref": "#/definitions/NullableUuid"},
                "sync_version": {"type": "integer", "minimum": 1},
                "deleted_at": {"$ref": "#/definitions/NullableCanonicalUtcTimestamp"},
                "gateway_device_eui": {"$ref": "#/definitions/Eui64"},
                "occurred_at": {"$ref": "#/definitions/CanonicalUtcTimestamp"}
            }
        },
        "UserPlotAssignmentCommand": {
            "allOf": [
                {"$ref": "#/definitions/UserPlotAssignment"},
                {
                    "required": ["base_sync_version"],
                    "propertyNames": {
                        "enum": ["assignment_uuid", "user_uuid", "plot_uuid", "assigned_by_user_uuid", "sync_version", "deleted_at", "gateway_device_eui", "occurred_at", "base_sync_version"]
                    },
                    "properties": {
                        "base_sync_version": {"type": "integer", "minimum": 0}
                    }
                }
            ]
        },
        "JournalEntryValue": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "attribute_code", "group_index", "value_status", "value_num", "value_text",
                "unit_code", "entered_value_num", "entered_unit_code"
            ],
            "properties": {
                "attribute_code": {"type": "string", "minLength": 1},
                "group_index": {"type": "integer", "minimum": 0},
                "value_status": {
                    "type": "string",
                    "enum": ["observed", "not_observed", "not_applicable", "below_detection"]
                },
                "value_num": {"type": ["number", "null"]},
                "value_text": {"type": ["string", "null"], "maxLength": 4096},
                "unit_code": {"type": ["string", "null"]},
                "entered_value_num": {"type": ["number", "null"]},
                "entered_unit_code": {"type": ["string", "null"]}
            },
            "oneOf": [
                {
                    "properties": {"value_status": {"const": "observed"}},
                    "oneOf": [
                        {"properties": {"value_num": {"type": "number"}, "value_text": {"type": "null"}}},
                        {"properties": {"value_num": {"type": "null"}, "value_text": {"type": "string"}}}
                    ]
                },
                {
                    "properties": {
                        "value_status": {"enum": ["not_observed", "not_applicable", "below_detection"]},
                        "value_num": {"const": null},
                        "value_text": {"const": null}
                    }
                }
            ]
        },
        "JournalEntry": {
            "type": "object",
            "additionalProperties": false,
            "x-aggregate-type": "JOURNAL_ENTRY",
            "x-watermark-key": "entry_uuid",
            "required": [
                "contract_version", "entry_uuid", "owner_user_uuid", "author_principal_uuid", "author_label",
                "plot_uuid", "zone_uuid", "device_eui", "season_uuid", "season_crop", "season_variety",
                "campaign_uuid", "protocol_code", "protocol_version", "observation_unit_code", "pass_uuid",
                "batch_uuid", "activity_code", "template_code", "template_version", "layout_code",
                "layout_version", "catalog_version", "occurred_start", "occurred_end", "occurred_timezone",
                "occurred_utc_offset_minutes", "recorded_at", "origin", "status", "voided_at",
                "voided_by_principal_uuid", "void_reason", "note", "context_json", "sync_version",
                "gateway_device_eui", "created_at", "updated_at", "deleted_at", "values"
            ],
            "properties": {
                "contract_version": {"type": "integer", "const": 1},
                "entry_uuid": {"$ref": "#/definitions/CanonicalUuid"},
                "base_sync_version": {"type": "integer", "minimum": 0},
                "owner_user_uuid": {"$ref": "#/definitions/Uuid"},
                "author_principal_uuid": {"$ref": "#/definitions/Uuid"},
                "author_label": {"type": ["string", "null"], "maxLength": 120},
                "plot_uuid": {"$ref": "#/definitions/NullableCanonicalUuid"},
                "zone_uuid": {"$ref": "#/definitions/NullableUuid"},
                "device_eui": {"$ref": "#/definitions/NullableEui64"},
                "season_uuid": {"$ref": "#/definitions/NullableUuid"},
                "season_crop": {"type": ["string", "null"]},
                "season_variety": {"type": ["string", "null"]},
                "campaign_uuid": {"$ref": "#/definitions/NullableUuid"},
                "protocol_code": {"type": ["string", "null"]},
                "protocol_version": {"type": ["string", "null"]},
                "observation_unit_code": {"type": ["string", "null"]},
                "pass_uuid": {"$ref": "#/definitions/NullableCanonicalUuid"},
                "batch_uuid": {"$ref": "#/definitions/NullableCanonicalUuid"},
                "activity_code": {"type": "string", "minLength": 1},
                "template_code": {"type": "string", "minLength": 1},
                "template_version": {"type": "integer", "minimum": 1},
                "layout_code": {"type": "string", "minLength": 1},
                "layout_version": {"type": "integer", "minimum": 1},
                "catalog_version": {"type": "integer", "minimum": 1},
                "occurred_start": {"$ref": "#/definitions/CanonicalUtcTimestamp"},
                "occurred_end": {"$ref": "#/definitions/NullableCanonicalUtcTimestamp"},
                "occurred_timezone": {"type": "string", "minLength": 1},
                "occurred_utc_offset_minutes": {"type": "integer", "minimum": -840, "maximum": 840},
                "recorded_at": {"$ref": "#/definitions/CanonicalUtcTimestamp"},
                "origin": {"type": "string", "enum": ["edge-ui", "cloud-ui"]},
                "status": {"type": "string", "enum": ["draft", "final", "voided"]},
                "voided_at": {"$ref": "#/definitions/NullableCanonicalUtcTimestamp"},
                "voided_by_principal_uuid": {"$ref": "#/definitions/NullableUuid"},
                "void_reason": {"type": ["string", "null"], "maxLength": 4000},
                "note": {"type": ["string", "null"], "maxLength": 4000},
                "context_json": {"type": ["string", "null"]},
                "sync_version": {"type": "integer", "minimum": 0},
                "gateway_device_eui": {"$ref": "#/definitions/Eui64"},
                "created_at": {"$ref": "#/definitions/CanonicalUtcTimestamp"},
                "updated_at": {"$ref": "#/definitions/CanonicalUtcTimestamp"},
                "deleted_at": {"$ref": "#/definitions/NullableCanonicalUtcTimestamp"},
                "values": {"type": "array", "maxItems": 128, "items": {"$ref": "#/definitions/JournalEntryValue"}}
            }
        },
        "JournalEntryAggregate": {
            "allOf": [
                {"$ref": "#/definitions/JournalEntry"},
                {"not": {"required": ["base_sync_version"]}}
            ]
        },
        "JournalEntryCommand": {
            "allOf": [
                {"$ref": "#/definitions/JournalEntry"},
                {"required": ["base_sync_version"]},
                {
                    "properties": {
                        "owner_user_uuid": {"$ref": "#/definitions/CanonicalUuid"},
                        "author_principal_uuid": {"$ref": "#/definitions/CanonicalUuid"}
                    }
                }
            ]
        },
        "JournalVocabMapping": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "scheme_uri", "scheme_version", "mapping_role", "external_id", "external_parent_id",
                "mapping_relation", "source_uri", "active"
            ],
            "properties": {
                "scheme_uri": {"type": "string", "minLength": 1},
                "scheme_version": {"type": "string", "minLength": 1},
                "mapping_role": {
                    "type": "string",
                    "enum": ["concept", "variable", "coded_value", "operation_type", "data_type_definition", "unit_of_measure"]
                },
                "external_id": {"type": "string", "minLength": 1},
                "external_parent_id": {"type": ["string", "null"]},
                "mapping_relation": {"type": "string", "enum": ["exact", "close", "broad", "narrow", "related"]},
                "source_uri": {"type": ["string", "null"]},
                "active": {"type": "integer", "enum": [0, 1]}
            }
        },
        "JournalVocab": {
            "type": "object",
            "additionalProperties": false,
            "x-aggregate-type": "JOURNAL_VOCAB",
            "x-watermark-key": "custom_field_uuid",
            "required": [
                "contract_version", "code", "kind", "parent_code", "value_type", "quantity_kind", "basis",
                "default_unit_code", "labels_json", "icon_key", "constraints_json", "agrovoc_uri", "icasa_code",
                "adapt_code", "scope", "owner_user_uuid", "gateway_device_eui", "custom_field_uuid", "active",
                "sort_order", "sync_version", "created_at", "deleted_at", "mappings"
            ],
            "properties": {
                "contract_version": {"type": "integer", "const": 1},
                "base_sync_version": {"type": "integer", "minimum": 0},
                "code": {"type": "string", "pattern": "^custom\\.[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"},
                "kind": {"type": "string", "enum": ["activity", "attribute", "unit", "choice"]},
                "parent_code": {"type": ["string", "null"]},
                "value_type": {"type": ["string", "null"], "enum": ["number", "text", "choice", "date", "boolean", null]},
                "quantity_kind": {"type": ["string", "null"]},
                "basis": {"type": ["string", "null"]},
                "default_unit_code": {"type": ["string", "null"]},
                "labels_json": {"type": "string", "minLength": 2},
                "icon_key": {"type": ["string", "null"]},
                "constraints_json": {"type": ["string", "null"]},
                "agrovoc_uri": {"type": ["string", "null"]},
                "icasa_code": {"type": ["string", "null"]},
                "adapt_code": {"type": ["string", "null"]},
                "scope": {"type": "string", "const": "custom"},
                "owner_user_uuid": {"$ref": "#/definitions/Uuid"},
                "gateway_device_eui": {"$ref": "#/definitions/Eui64"},
                "custom_field_uuid": {"$ref": "#/definitions/CanonicalUuid"},
                "active": {"type": "integer", "enum": [0, 1]},
                "sort_order": {"type": "integer"},
                "sync_version": {"type": "integer", "minimum": 0},
                "created_at": {"$ref": "#/definitions/CanonicalUtcTimestamp"},
                "deleted_at": {"$ref": "#/definitions/NullableCanonicalUtcTimestamp"},
                "mappings": {"type": "array", "items": {"$ref": "#/definitions/JournalVocabMapping"}}
            }
        },
        "JournalVocabAggregate": {
            "allOf": [
                {"$ref": "#/definitions/JournalVocab"},
                {"not": {"required": ["base_sync_version"]}}
            ]
        },
        "JournalVocabCommand": {
            "allOf": [
                {"$ref": "#/definitions/JournalVocab"},
                {"required": ["base_sync_version"]},
                {
                    "properties": {
                        "owner_user_uuid": {"$ref": "#/definitions/CanonicalUuid"}
                    }
                }
            ]
        },
        "JournalPlotSettings": {
            "type": "object",
            "additionalProperties": false,
            "required": ["layout_code", "updated_at", "updated_by_principal_uuid", "sync_version"],
            "properties": {
                "layout_code": {"type": "string", "minLength": 1},
                "updated_at": {"$ref": "#/definitions/CanonicalUtcTimestamp"},
                "updated_by_principal_uuid": {"$ref": "#/definitions/Uuid"},
                "sync_version": {"type": "integer", "minimum": 0}
            }
        },
        "JournalPlot": {
            "type": "object",
            "additionalProperties": false,
            "x-aggregate-type": "JOURNAL_PLOT",
            "x-watermark-key": "plot_uuid",
            "required": [
