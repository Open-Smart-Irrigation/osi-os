{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://contracts.opensmartirrigation.org/sync-schema/events.schema.json",
    "title": "Sync Event",
    "x-semantic-bindings": {
        "JOURNAL_ENTRY_UPSERTED": {"aggregate_key_path": "payload.entry_uuid", "sync_version_path": "payload.sync_version"},
        "JOURNAL_ENTRY_VOIDED": {"aggregate_key_path": "payload.entry_uuid", "sync_version_path": "payload.sync_version"},
        "JOURNAL_VOCAB_UPSERTED": {"aggregate_key_path": "payload.custom_field_uuid", "sync_version_path": "payload.sync_version"},
        "JOURNAL_PLOT_UPSERTED": {"aggregate_key_path": "payload.plot_uuid", "sync_version_path": "payload.sync_version"},
        "JOURNAL_PLOT_GROUP_UPSERTED": {"aggregate_key_path": "payload.group_uuid", "sync_version_path": "payload.sync_version"}
    },
    "type": "object",
    "required": ["eventUuid", "aggregateType", "aggregateKey", "op", "syncVersion", "payload"],
    "additionalProperties": false,
    "properties": {
        "eventUuid": {"type": "string", "minLength": 1},
        "aggregateType": {
            "type": "string",
            "description": "Event stream aggregate type. Canonical resource payloads are described in resources.schema.json; other aggregates are event-only command or telemetry payloads.",
            "minLength": 1
        },
        "aggregateKey": {"type": "string", "minLength": 1},
        "op": {
            "type": "string",
            "description": "Sync event operation emitted by the edge and handled by the cloud EdgeSyncService runtime dispatch.",
            "enum": [
                "CHAMELEON_READING_APPENDED",
                "DENDRO_DAILY_UPSERTED",
                "DENDRO_READING_APPENDED",
                "DEVICE_ASSIGNED",
                "DEVICE_DATA_APPENDED",
                "DEVICE_FLAGS_UPDATED",
                "DEVICE_UNASSIGNED",
                "DEVICE_UNCLAIMED",
                "GATEWAY_LOCATION_UPSERTED",
                "IRRIGATION_EVENT_APPENDED",
                "SCHEDULE_UPSERTED",
                "USER_PLOT_ASSIGNMENT_DELETED",
                "USER_PLOT_ASSIGNMENT_UPSERTED",
                "USER_UPSERTED",
                "USER_ZONE_ASSIGNMENT_DELETED",
                "USER_ZONE_ASSIGNMENT_UPSERTED",
                "WORK_REQUEST_SUBMITTED",
                "ZONE_CONFIG_UPSERTED",
                "ZONE_DELETED",
                "ZONE_ENVIRONMENT_APPENDED",
                "ZONE_LOCATION_UPSERTED",
                "ZONE_RECOMMENDATION_UPSERTED",
                "ZONE_UPSERTED",
                "JOURNAL_ENTRY_UPSERTED",
                "JOURNAL_ENTRY_VOIDED",
                "JOURNAL_VOCAB_UPSERTED",
                "JOURNAL_PLOT_UPSERTED",
                "JOURNAL_PLOT_GROUP_UPSERTED"
            ]
        },
        "syncVersion": {"type": "integer", "minimum": 0},
        "occurredAt": {"type": ["string", "null"], "format": "date-time"},
        "payload": {
            "type": "object",
            "required": ["contract_version"],
            "additionalProperties": true,
            "properties": {
                "contract_version": {
                    "type": "integer",
                    "const": 1,
                    "description": "Sync event contract version stamped into every emitted sync_outbox payload JSON."
                }
            }
        }
    },
    "allOf": [
        {
            "if": {
                "properties": {
                    "op": {
                        "enum": [
                            "JOURNAL_ENTRY_UPSERTED",
                            "JOURNAL_ENTRY_VOIDED",
                            "JOURNAL_VOCAB_UPSERTED",
                            "JOURNAL_PLOT_UPSERTED",
                            "JOURNAL_PLOT_GROUP_UPSERTED"
                        ]
                    }
                },
                "required": ["op"]
            },
            "then": {
                "required": ["occurredAt"],
                "properties": {
                    "occurredAt": {"$ref": "resources.schema.json#/definitions/CanonicalUtcTimestamp"}
                }
            }
        },
        {
            "if": {
                "properties": {"op": {"const": "JOURNAL_ENTRY_UPSERTED"}},
                "required": ["op"]
            },
            "then": {
                "properties": {
                    "aggregateType": {"const": "JOURNAL_ENTRY"},
                    "aggregateKey": {"$ref": "resources.schema.json#/definitions/CanonicalUuid"},
                    "payload": {
                        "allOf": [
                            {"$ref": "resources.schema.json#/definitions/JournalEntryAggregate"},
                            {
                                "required": ["status"],
                                "properties": {"status": {"const": "final"}}
                            }
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {"op": {"const": "JOURNAL_ENTRY_VOIDED"}},
                "required": ["op"]
            },
            "then": {
                "properties": {
                    "aggregateType": {"const": "JOURNAL_ENTRY"},
                    "aggregateKey": {"$ref": "resources.schema.json#/definitions/CanonicalUuid"},
                    "payload": {
                        "allOf": [
                            {"$ref": "resources.schema.json#/definitions/JournalEntryAggregate"},
                            {
                                "required": ["status", "voided_at", "voided_by_principal_uuid", "void_reason"],
                                "properties": {
                                    "status": {"const": "voided"},
                                    "voided_at": {"$ref": "resources.schema.json#/definitions/CanonicalUtcTimestamp"},
                                    "voided_by_principal_uuid": {"$ref": "resources.schema.json#/definitions/Uuid"},
                                    "void_reason": {"type": "string", "minLength": 1, "maxLength": 4000}
                                }
                            }
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {"op": {"const": "JOURNAL_VOCAB_UPSERTED"}},
                "required": ["op"]
            },
            "then": {
                "properties": {
                    "aggregateType": {"const": "JOURNAL_VOCAB"},
                    "aggregateKey": {"$ref": "resources.schema.json#/definitions/CanonicalUuid"},
                    "payload": {"$ref": "resources.schema.json#/definitions/JournalVocabAggregate"}
                }
            }
        },
        {
            "if": {
                "properties": {"op": {"const": "JOURNAL_PLOT_UPSERTED"}},
                "required": ["op"]
            },
            "then": {
                "properties": {
                    "aggregateType": {"const": "JOURNAL_PLOT"},
                    "aggregateKey": {"$ref": "resources.schema.json#/definitions/CanonicalUuid"},
                    "payload": {"$ref": "resources.schema.json#/definitions/JournalPlotAggregate"}
                }
            }
        },
        {
            "if": {
                "properties": {"op": {"const": "JOURNAL_PLOT_GROUP_UPSERTED"}},
                "required": ["op"]
            },
            "then": {
                "properties": {
                    "aggregateType": {"const": "JOURNAL_PLOT_GROUP"},
                    "aggregateKey": {"$ref": "resources.schema.json#/definitions/CanonicalUuid"},
                    "payload": {"$ref": "resources.schema.json#/definitions/JournalPlotGroupAggregate"}
                }
            }
        }
    ]
}
