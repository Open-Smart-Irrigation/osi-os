        "plot_group": {"$ref": "resources.schema.json#/definitions/JournalPlotGroup"},
        "user": {"$ref": "resources.schema.json#/definitions/ScopedUserCommand"},
        "zone_assignment": {"$ref": "resources.schema.json#/definitions/UserZoneAssignmentCommand"},
        "plot_assignment": {"$ref": "resources.schema.json#/definitions/UserPlotAssignmentCommand"},
        "assignment_uuid": {"$ref": "resources.schema.json#/definitions/Uuid"},
        "user_uuid": {"$ref": "resources.schema.json#/definitions/Uuid"},
        "password_hash": {"type": "string", "pattern": "^\\$2[aby]\\$[0-9]{2}\\$.{53}$"},
        "zone_uuid": {"$ref": "resources.schema.json#/definitions/CanonicalUuid"},
        "gateway_device_eui": {"$ref": "resources.schema.json#/definitions/Eui64"},
        "target_sync_version": {"type": "integer", "minimum": 1},
        "zone": {},
        "schedule": {"$ref": "resources.schema.json#/definitions/IrrigationScheduleDesiredState"},
        "irrigation_calibration": {"$ref": "resources.schema.json#/definitions/IrrigationCalibrationDesiredState"}
    },
    "allOf": [
        {
            "if": {
                "properties": {
                    "command_type": {
                        "enum": [
                            "UPSERT_JOURNAL_ENTRY",
                            "VOID_JOURNAL_ENTRY",
