                        "pattern": "^journal_plot_group:[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}:(?:0|[1-9][0-9]*)$"
                    },
                    "plot_group": {"$ref": "resources.schema.json#/definitions/JournalPlotGroupCommand"}
