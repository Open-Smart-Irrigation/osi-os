                },
                "properties": {
                    "effect_key": {
                        "type": "string",
                        "pattern": "^journal_plot:[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}:(?:0|[1-9][0-9]*)$"
