                "SET_LSN50_INTERVAL",
                "SET_LSN50_INTERRUPT_MODE",
                "SET_LSN50_5V_WARMUP",
                "SET_KIWI_INTERVAL",
                "ENABLE_KIWI_TEMP_HUMIDITY",
                "SET_CHAMELEON_CONFIG",
                "REGISTER_DEVICE",
                "REBOOT",
                "REBOOT_DEVICE",
                "REMOVE_DEVICE_FROM_ZONE",
                "UNCLAIM_DEVICE",
                "SET_FAN",
                "FORCE_EDGE_SYNC",
                "SYNC_LINKED_AUTH",
                "UPSERT_ZONE",
                "DELETE_ZONE",
                "UPSERT_ZONE_CONFIG",
                "UPSERT_ZONE_LOCATION",
                "ASSIGN_DEVICE_TO_ZONE",
                "UPSERT_DEVICE_FLAGS",
                "UPSERT_DEVICE_SOIL_DEPTHS",
                "UPDATE_SCHEDULE",
                "UPSERT_SCHEDULE",
                "UPSERT_ZONE_IRRIGATION_CALIBRATION",
                "WORK_REQUEST_STATUS",
                "UPSERT_JOURNAL_ENTRY",
                "VOID_JOURNAL_ENTRY",
                "UPSERT_JOURNAL_CUSTOM_VOCAB",
                "UPSERT_JOURNAL_PLOT",
                "UPSERT_JOURNAL_PLOT_GROUP",
                "UPSERT_SCOPED_USER",
                "RESET_SCOPED_USER_PASSWORD",
                "UPSERT_USER_ZONE_ASSIGNMENT",
                "DELETE_USER_ZONE_ASSIGNMENT",
                "UPSERT_USER_PLOT_ASSIGNMENT",
                "DELETE_USER_PLOT_ASSIGNMENT"
            ]
        },
        "device_eui": {"type": "string", "pattern": "^[0-9A-F]{16}$"},
        "zone_id": {"type": ["integer", "null"]},
        "duration_seconds": {"type": ["integer", "null"], "minimum": 1},
        "duration_minutes": {"type": ["integer", "null"], "minimum": 1},
        "amount": {"type": ["integer", "null"], "minimum": 1},
        "unit": {"type": ["string", "null"], "enum": ["SECONDS", "MINUTES", "HOURS", null]},
        "action": {"type": ["string", "null"], "enum": ["OPEN", "CLOSE", null]},
        "effect_key": {"type": ["string", "null"]},
        "issued_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": ["string", "null"], "format": "date-time"},
        "config": {"type": ["object", "null"]},
        "request_id": {"type": ["string", "null"]},
        "status": {"type": ["string", "null"]},
        "reason": {"type": ["string", "null"]},
        "human_message": {"type": ["string", "null"]},
        "released_version": {"type": ["string", "null"]},
        "updated_at": {"type": ["string", "null"], "format": "date-time"},
