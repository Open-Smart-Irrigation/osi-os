#!/bin/sh /etc/rc.common

START=101
STOP=20

USE_PROCD=1

SERVICE_NAME=osi-gateway-gps
PROG=/usr/bin/node
SCRIPT=/usr/bin/osi-gateway-gps.js
IDENTITY_HELPER=/usr/libexec/osi-gateway-identity.sh

start_service() {
	local enabled
	local device_eui
	local device_eui_source
	local device_eui_confidence
	local device_eui_last_verified_at

	config_load osi-gateway-gps
	config_get_bool enabled core enabled 1
	[ "$enabled" -eq 1 ] || return 1

	if [ -x "$IDENTITY_HELPER" ]; then
		eval "$("$IDENTITY_HELPER" resolve 2>/dev/null || true)"
	fi

	device_eui="${DEVICE_EUI:-$(uci -q get osi-server.cloud.device_eui 2>/dev/null || echo "")}"
	device_eui_source="${DEVICE_EUI_SOURCE:-$(uci -q get osi-server.cloud.device_eui_source 2>/dev/null || echo "")}"
	device_eui_confidence="${DEVICE_EUI_CONFIDENCE:-$(uci -q get osi-server.cloud.device_eui_confidence 2>/dev/null || echo "provisional")}"
	device_eui_last_verified_at="${DEVICE_EUI_LAST_VERIFIED_AT:-$(uci -q get osi-server.cloud.device_eui_last_verified_at 2>/dev/null || echo "")}"

	procd_open_instance
	procd_set_param command "$PROG" "$SCRIPT"
	procd_set_param env \
		DEVICE_EUI="$device_eui" \
		DEVICE_EUI_SOURCE="$device_eui_source" \
		DEVICE_EUI_CONFIDENCE="$device_eui_confidence" \
		DEVICE_EUI_LAST_VERIFIED_AT="$device_eui_last_verified_at"
	procd_set_param respawn 3600 5 -1
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger osi-gateway-gps gpsd osi-server chirpstack-concentratord
}
