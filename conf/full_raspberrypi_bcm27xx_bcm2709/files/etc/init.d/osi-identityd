#!/bin/sh /etc/rc.common

START=98
STOP=98

USE_PROCD=1
EXTRA_COMMANDS="ready"
EXTRA_HELP="\tready\tCheck whether identityd owns a live consumer lock"

start_service() {
	procd_open_instance
	procd_set_param command /usr/libexec/osi-identityd.sh start
	procd_set_param respawn 3600 5 -1
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

ready() {
	service_running || return 1
	/usr/libexec/osi-identityd.sh ready
}
