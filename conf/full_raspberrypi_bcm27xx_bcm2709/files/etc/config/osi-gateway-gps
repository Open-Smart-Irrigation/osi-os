config core 'core'
	option enabled '1'
	option gpsd_host '127.0.0.1'
	option gpsd_port '2947'
	option poll_interval_s '60'
	option stale_after_s '900'
	option min_move_m '20'
	option native_probe_enabled '1'
	option chirpstack_mirror_enabled '1'
	option chirpstack_mirror_threshold_m '20'
	option serial_device '/dev/ttyAMA0'
	option serial_baud '9600'
